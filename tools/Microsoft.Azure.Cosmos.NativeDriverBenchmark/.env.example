# Copy this file to `.env` (same folder) and fill in your real values.
# `.env` is gitignored — never commit a real key.
#
# Load into the current PowerShell session with:
#   . .\scripts\Load-Env.ps1
#
# Then run:
#   dotnet run -c Release -- validate
#   dotnet run -c Release

COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-key>
COSMOS_DATABASE=<your-db>
COSMOS_CONTAINER=<your-container>
COSMOS_ITEM_ID=<ITEM-ID>
COSMOS_PARTITION_KEY=<PK>
