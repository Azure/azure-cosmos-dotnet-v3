<Project Sdk="Microsoft.NET.Sdk">

  <!-- NEW subprocess: Microsoft.Azure.Cosmos.Encryption.Custom 1.1.0-preview01 from the local feed. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>CompatMatrix.New</AssemblyName>
    <RootNamespace>CompatMatrix</RootNamespace>
    <DefineConstants>$(DefineConstants);CEC_NEW</DefineConstants>
    <SignAssembly>false</SignAssembly>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\src\Program.cs" Link="Program.cs" />
    <Compile Include="..\src\KeyProviders.cs" Link="KeyProviders.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Cosmos.Encryption.Custom" Version="[1.1.0-preview01]" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
