<?xml version="1.0" encoding="utf-8"?>
<!-- Standalone restore config for the compat-matrix subprocesses.
     OLD (1.0.0-preview07) comes from nuget.org, NEW (2.0.0-preview01) from the local feed.
     The Encryption.Custom package id must be resolvable from BOTH feeds: local-feed only
     ships preview01, nuget.org only ships preview07, so each project resolves its pinned
     version from whichever feed has it. All other transitive deps come from nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local-feed" value="..\..\..\..\local-feed" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Microsoft.Azure.Cosmos.Encryption.Custom" />
    </packageSource>
    <packageSource key="local-feed">
      <package pattern="Microsoft.Azure.Cosmos.Encryption.Custom" />
    </packageSource>
  </packageSourceMapping>
</configuration>
